# SR2 EDI Agent — Environment Variables
# Copy to .env and fill in required values.

# ── Required ─────────────────────────────────────────────────
# PostgreSQL (used for sessions, memories, heartbeats)
DATABASE_URL=postgresql://sr2:sr2@localhost:5432/sr2

# Ollama (local LLM inference)
OLLAMA_API_BASE=http://localhost:11434

# OpenAI API key (used for embedding model: text-embedding-3-small)
# Required if memory retrieval is enabled.
OPENAI_API_KEY=

# ── Optional ─────────────────────────────────────────────────
# SearXNG instance URL (for web search MCP server)
# SEARXNG_URL=http://localhost:8765

# Galaxy Map task board URL (for task management MCP server)
# GALAXY_MAP_URL=http://localhost:8000

# ── Docker Compose ───────────────────────────────────────────
# Used by prometheus/grafana containers for file ownership
# UID=1000
# GID=1000
